PORT=5000
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/carepulse?retryWrites=true&w=majority
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
# 6-digit code used to unlock /admin
ADMIN_PASSKEY=
CLIENT_ORIGIN=http://localhost:5173
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUDIO_ENCRYPTION_KEY=
# Local NLLB translation server (optional -- translate UI hides if unreachable).
# Covers English, Hindi, Kannada. Set up with `npm run setup:translate`, then run
# pyservices/translate_server.py (see that script). Serves on :5555 by default.
TRANSLATE_URL=http://localhost:5555
# RabbitMQ broker (optional -- start with `docker compose up -d` at the repo
# root, then run the speech worker with `npm run worker`). If unreachable, the
# API processes speech in-process instead of dispatching to the worker.
RABBITMQ_URL=amqp://localhost:5672
# Retention window in days (optional). When set, each service hard-deletes
# its own expired data daily: completed conversation sessions (audio +
# transcript + audit entries) older than this, and reminders whose course
# ended more than this many days ago. UNSET = retention disabled; nothing is
# ever auto-deleted.
# RETENTION_DAYS=365

# --- Deployment (combined-server.js on a single host, e.g. Render free) ---
# Frontend origin(s) allowed by CORS -- your deployed frontend URL, e.g.
# https://carepulse.vercel.app (comma-separated for more than one). localhost
# is always allowed. Only needed for the hosted combined server.
CLIENT_ORIGIN=https://your-frontend.vercel.app
# Single database for the combined single-process deploy (the split
# architecture uses four: carepulse_auth/_patients/_conversations/_notifications).
COMBINED_DB=carepulse
# PORT is injected by the host (Render etc.); combined-server falls back to 5000.

# --- Neural diarization (Day 31, optional but much more accurate) ---
# Free Hugging Face READ token (hf.co/settings/tokens). Also accept the model
# licenses once on your account: pyannote/segmentation-3.0 and
# pyannote/speaker-diarization-3.1. When set (and pyannote.audio is installed
# in PYANNOTE_PYTHON's venv), diarization uses pyannote and falls back to the
# MFCC clustering if anything goes wrong. Unset = MFCC clustering as before.
# HF_TOKEN=hf_...
# Python with pyannote.audio installed (defaults to D:\cpt\Scripts\python.exe,
# the same venv the NLLB translate server uses). It lives at a short drive-root
# path because torch's deep file tree exceeds Windows MAX_PATH under the repo --
# and on a non-system drive to keep the multi-GB install off C:.
# PYANNOTE_PYTHON=D:\cpt\Scripts\python.exe
# TRANSLATE_VENV=D:\cpt

# --- Whisper model choice (Day 32) ---
# "small" (~466MB) transcribes drug names markedly better than "base"
# (~148MB) -- in our 3-speaker test, medications extracted went 0/3 -> 2/3 --
# at roughly 2-3x the transcription time. Download it once into
# backend/bin/whisper/models/ :
#   curl -L -o bin/whisper/models/ggml-small.bin \
#     https://huggingface.co/ggerganov/whisper.cpp/resolve/main/ggml-small.bin
# Then point the HOST worker at it (containers are pinned to the Linux path
# in docker-compose.yml, which overrides this):
# WHISPER_MODEL=D:\path\to\mern\backend\bin\whisper\models\ggml-small.bin

# --- Keep big model caches off the system drive (Day 33) ---
# HuggingFace downloads (NLLB ~2.4GB, pyannote ~2GB) default to
# C:\Users\<you>\.cache\huggingface. Point them at a roomier drive instead.
# Also set it as a user env var so any python you run picks it up:
#   [Environment]::SetEnvironmentVariable("HF_HOME","D:\hf-cache","User")
# HF_HOME=D:\hf-cache
