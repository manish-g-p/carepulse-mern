PORT=5000
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/carepulse?retryWrites=true&w=majority
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
# 6-digit code used to unlock /admin
ADMIN_PASSKEY=
CLIENT_ORIGIN=http://localhost:5173
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUDIO_ENCRYPTION_KEY=
# Local NLLB translation server (optional -- translate UI hides if unreachable).
# Covers English, Hindi, Kannada. Set up with `npm run setup:translate`, then run
# pyservices/translate_server.py (see that script). Serves on :5555 by default.
TRANSLATE_URL=http://localhost:5555
# RabbitMQ broker (optional -- start with `docker compose up -d` at the repo
# root, then run the speech worker with `npm run worker`). If unreachable, the
# API processes speech in-process instead of dispatching to the worker.
RABBITMQ_URL=amqp://localhost:5672
# Retention window in days (optional). When set, each service hard-deletes
# its own expired data daily: completed conversation sessions (audio +
# transcript + audit entries) older than this, and reminders whose course
# ended more than this many days ago. UNSET = retention disabled; nothing is
# ever auto-deleted.
# RETENTION_DAYS=365
