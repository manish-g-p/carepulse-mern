# API base URL. Local dev goes through the nginx gateway on :8080; a deployed
# build points at the hosted backend, e.g. https://carepulse-api.onrender.com/api
VITE_API_URL=http://localhost:8080/api

# Set to "true" in the hosted free demo to show the banner explaining that
# recording/transcription/translation run in the local full stack (the
# on-device AI needs more RAM than a free host provides). Leave unset locally.
VITE_DEMO_MODE=

